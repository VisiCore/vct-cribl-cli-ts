{
  "name": "cribl-cli",
  "version": "0.1.0",
  "description": "CLI for Cribl Cloud REST API",
  "type": "module",
  "bin": {
    "cribl": "./dist/bin/cribl.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/cribl.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["cribl", "cli", "observability"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "nock": "^14.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
