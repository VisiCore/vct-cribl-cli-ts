# Cribl Cloud authentication
CRIBL_BASE_URL=https://your-org.cribl.cloud
CRIBL_CLIENT_ID=your-client-id
CRIBL_CLIENT_SECRET=your-client-secret

# Or local/on-prem authentication
# CRIBL_BASE_URL=https://your-cribl-instance:9000
# CRIBL_USERNAME=admin
# CRIBL_PASSWORD=your-password

# Optional
# CRIBL_PROFILE=default
